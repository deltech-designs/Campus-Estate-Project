{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["BACKEND_API_URL"],
  "tasks": {
   "build": {
      "dependsOn": ["^build"],
      "env": ["BACKEND_API_URL"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "clean": {
      "cache": false
    }
  }
}
